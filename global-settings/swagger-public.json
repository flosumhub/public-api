      },
      "GrantType": {
        "type": "string",
        "enum": [
          "authorization_code",
          "refresh_token"
        ],
        "description": "OAuth grant type"
      },
      "OAuthTokenBodyDto": {
        "type": "object",
        "properties": {
          "grant_type": {
            "description": "OAuth grant type",
            "example": "authorization_code",
            "allOf": [
              {
                "$ref": "#/components/schemas/GrantType"
              }
            ]
          },
          "code": {
            "type": "string",
            "description": "Authorization code extracted from OAuth /authorize response parameters(used when grant_type=authorization_code)",
            "example": "abc123def456ghi789"
          },
          "refresh_token": {
            "type": "string",
            "description": "Refresh token code extracted from OAuth /token response parameters(used when grant_type=refresh_token)",
            "example": "abcd0123efgh4567ijkl8901mnop2345qrst6789uvwx0123yzab4567cdef8901ghij2345"
          },
          "redirect_uri": {
            "type": "string",
            "description": "Allowed redirect URI",
            "example": "https://yourapp.com/oauth/callback"
          },
          "client_id": {
            "type": "string",
            "description": "Client identifier (from connected app)",
            "example": "fci_abC12_dEfGhijkLMnopQrs"
          },
          "client_secret": {
            "type": "string",
            "description": "Client secret (from connected app)",
            "example": "abCdEF1gHiJKl_mn-op234qrst56789uvWXyzAbcDEf"
          }
        },
        "required": [
          "grant_type",
          "redirect_uri",
          "client_id",
          "client_secret"
        ]
      },
      "TokenResponseDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string",
            "nullable": true
          },
          "expires_in": {
            "type": "number"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "refresh_token",
          "expires_in"
        ]
      }
